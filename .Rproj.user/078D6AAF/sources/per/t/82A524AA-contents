  group_by(neighbourhood) |> 
  summarise(n = n(), 
            developments = n_distinct(building_name), 
            median_psf = median(psf)) |> 
  filter(n > 10 & developments >= 3) |> 
  arrange(desc(median_psf)) |> 
  pull(neighbourhood)


houses_clean |> 
