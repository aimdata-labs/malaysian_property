```{r data}
houses <- read_csv("./data/houses.csv") |> 
  janitor::clean_names()|>
  mutate(
    size_sqft = str_remove_all(property_size, "sq.ft."),
    price = str_remove_all(price, "RM"),
    price = gsub("[^0-9.-]", "", price), 
    price = as.numeric(price), 
    developer = str_remove_all(developer, "Sdn. Bhd.|Sdn Bhd"), 
    size_sqft = as.numeric(size_sqft)
  ) |> 
  filter(address != "-") |> 
  mutate(psf = price / size_sqft)

